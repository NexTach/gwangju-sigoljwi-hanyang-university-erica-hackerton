{
  "name": "road-dna",
  "version": "0.1.0",
  "private": true,
  "description": "Road DNA accessibility crowdsensing platform",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm --filter @road-dna/design-tokens build && pnpm -r --if-present build",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "pnpm --parallel --filter @road-dna/api --filter @road-dna/dashboard dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
