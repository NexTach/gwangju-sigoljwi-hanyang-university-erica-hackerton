HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
DEMO_MODE=false
PUBLIC_PATH_PREFIX=/road-dna
CORS_ORIGINS=https://kimtaeeun.site,https://www.kimtaeeun.site

# The on-premise host publishes the existing MySQL and Redis containers.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-existing-root-password
MYSQL_DATABASE=road_dna
MYSQL_CONNECTION_LIMIT=10
REDIS_URL=redis://:replace-with-existing-redis-password@host.docker.internal:6379
EVENT_RETENTION_DAYS=90

ROAD_DNA_PORT=18080
